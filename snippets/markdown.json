{
  "Markdown hyperlink": {
    "prefix": "link",
    "description": "A hyperlink",
    "body": ["[${1:text}](${2:url})"]
  },
  "Markdown image": {
    "prefix": "img",
    "description": "An image",
    "body": ["![${1:alt}](${2:src})"]
  },
  "Markdown code block": {
    "prefix": "code",
    "description": "A code block",
    "body": ["```${1:language}", "${2:code}", "```"]
  },
  "GitHub markdown info alert": {
    "prefix": "gh-info",
    "description": "A GitHub flavored note alert",
    "body": ["> [!NOTE]", "> ${1:text}"]
  },
  "GitHub markdown tip alert": {
    "prefix": "gh-tip",
    "description": "A GitHub flavored tip alert",
    "body": ["> [!TIP]", "> ${1:text}"]
  },
  "GitHub markdown important alert": {
    "prefix": "gh-important",
    "description": "A GitHub flavored important alert",
    "body": ["> [!IMPORTANT]", "> ${1:text}"]
  },
  "GitHub markdown warning alert": {
    "prefix": "gh-warning",
    "description": "A GitHub flavored warning alert",
    "body": ["> [!WARNING]", "> ${1:text}"]
  },
  "GitHub markdown caution alert": {
    "prefix": "gh-caution",
    "description": "A GitHub flavored caution alert",
    "body": ["> [!CAUTION]", "> ${1:text}"]
  },
  "Markdown Comment": {
    "prefix": "cmt",
    "description": "A comment",
    "body": ["<!-- ${1:text} -->"]
  },
  "Markdown CSS code block": {
    "prefix": "code-css",
    "description": "A CSS code block",
    "body": ["```css", "${1:/* code */}", "```", "", "$2"]
  },
  "Markdown TypeScript code block": {
    "prefix": "code-ts",
    "description": "A TypeScript code block",
    "body": ["```ts", "${1:// code}", "```", "", "$2"]
  },
  "Markdown JavaScript code block": {
    "prefix": "code-js",
    "description": "A JavaScript code block",
    "body": ["```js", "${1:// code}", "```", "", "$2"]
  },
  "Markdown JSX code block": {
    "prefix": "code-jsx",
    "description": "A JSX code block",
    "body": ["```jsx", "${1:// code}", "```", "", "$2"]
  },
  "Markdown TSX code block": {
    "prefix": "code-tsx",
    "description": "A TSX code block",
    "body": ["```tsx", "${1:// code}", "```", "", "$2"]
  },
  "Markdown Bash code block": {
    "prefix": "code-bash",
    "description": "A Bash code block",
    "body": ["```bash", "${1:# code}", "```", "", "$2"]
  },
  "Markdown YAML code block": {
    "prefix": "code-yaml",
    "description": "A YAML code block",
    "body": ["```yaml", "${1:# code}", "```", "", "$2"]
  },
  "Markdown SQL code block": {
    "prefix": "code-sql",
    "description": "A SQL code block",
    "body": ["```sql", "${1:-- code}", "```", "", "$2"]
  },
  "Markdown JSON code block": {
    "prefix": "code-json",
    "description": "A JSON code block",
    "body": ["```json", "$0", "```", "", "$2"]
  },
  "Markdown HTML code block": {
    "prefix": "code-html",
    "description": "An HTML code block",
    "body": ["```html", "${1:<!-- code -->}", "```", "", "$2"]
  },
  "Markdown Markdown code block": {
    "prefix": "code-md",
    "description": "A Markdown code block",
    "body": ["```md", "${1:<!-- code -->}", "```", "", "$2"]
  },
  "Markdown Python code block": {
    "prefix": "code-py",
    "description": "A Python code block",
    "body": ["```py", "${1:# code}", "```", "", "$2"]
  },
  "Markdown Rust code block": {
    "prefix": "code-rs",
    "description": "A Rust code block",
    "body": ["```rs", "${1:// code}", "```", "", "$2"]
  },
  "Markdown Go code block": {
    "prefix": "code-go",
    "description": "A Go code block",
    "body": ["```go", "${1:// code}", "```", "$2"]
  },
  "Markdown TOML code block": {
    "prefix": "code-toml",
    "description": "A TOML code block",
    "body": ["```toml", "${1:# code}", "```", "", "$2"]
  },
  "Markdown horizontal rule": {
    "prefix": "hr",
    "description": "A horizontal rule",
    "body": ["---", "", "$1"]
  },
  "Markdown inline code": {
    "prefix": "icode",
    "description": "An inline code block",
    "body": ["`${1:code}`"]
  },
  "Markdown bold": {
    "prefix": "b",
    "description": "Bold text",
    "body": ["**${1:bold}**"]
  },
  "Markdown italic": {
    "prefix": "i",
    "description": "Italic text",
    "body": ["_${1:italic}_"]
  },
  "Markdown strikethrough": {
    "prefix": "s",
    "description": "Strikethrough text",
    "body": ["~~${1:strike}~~"]
  },
  "Markdown h1": {
    "prefix": "h1",
    "description": "Heading 1",
    "body": ["# ${1:heading}", "", "$2"]
  },
  "Markdown h2": {
    "prefix": "h2",
    "description": "Heading 2",
    "body": ["## ${1:heading}", "", "$2"]
  },
  "Markdown h3": {
    "prefix": "h3",
    "description": "Heading 3",
    "body": ["### ${1:heading}", "", "$2"]
  },
  "Markdown h4": {
    "prefix": "h4",
    "description": "Heading 4",
    "body": ["#### ${1:heading}", "", "$2"]
  },
  "Markdown h5": {
    "prefix": "h5",
    "description": "Heading 5",
    "body": ["##### ${1:heading}", "", "$2"]
  },
  "Markdown h6": {
    "prefix": "h6",
    "description": "Heading 6",
    "body": ["###### ${1:heading}", "", "$2"]
  },
}
